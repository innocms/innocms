{
    "name": "innoshop/devtools",
    "description": "InnoCMS Developer Tools - Plugin and Theme Development Toolkit",
    "type": "library",
    "license": "OSL-3.0",
    "authors": [
        {
            "name": "InnoCMS",
            "email": "team@innoshop.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^11.0",
        "illuminate/console": "^11.0",
        "illuminate/filesystem": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "InnoCMS\\DevTools\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "InnoCMS\\DevTools\\DevToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

